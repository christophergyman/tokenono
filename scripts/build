#!/usr/bin/env bash
set -euo pipefail

CC="cc"
CFLAGS="-Wall -Wextra -O2"
INCLUDE="-I/opt/homebrew/Cellar/raylib/5.5/include"
LDFLAGS="-L/opt/homebrew/Cellar/raylib/5.5/lib -lraylib -framework Cocoa -framework IOKit -framework OpenGL"

echo "=== Building ==="
$CC $CFLAGS $INCLUDE -o bin/square src/main.c $LDFLAGS

echo "=== Done ==="
echo "Running..."
./bin/square
